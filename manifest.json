{
  "manifest_version": 3,
  "name": "Claude Element Selector",
  "version": "1.0.0",
  "description": "Selecione componentes React e copie contexto para o Claude",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Claude Element Selector"
  }
}
